@model WebApplication2.Models.LoginView
@{
	ViewData["Title"] = "Sign In";
}
<div class="login-container">
	<div class="login-card">
		<div><h3 class="login-title">Sign In</h3></div>

		<form asp-action="Login" method="post">
			<div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>
			
			<div class="mb-3">
				<label asp-for="Username" class="form-label"></label>
				<input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="username" />
				<span asp-validation-for="Username" class="text-danger small"></span>
			</div>

			<div class="mb-3">
				<label asp-for="Password" class="form-label"></label>
				<div class="password-wrapper">
					<input asp-for="Password" id="Password" type="password" class="form-control password-input" placeholder="Enter your Password" autocomplete="current-password" />
					<button type="button" class="password-toggle" aria-label="Show password" aria-pressed="false" title="Show password">
						<svg class="eye-icon eye-closed" viewBox="0 0 576 512" width="20" height="20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M572.52 241.4C518.29 135.59 410.97 64 288 64 165.03 64 57.71 135.59 3.48 241.4a48.3 48.3 0 000 29.2C57.71 376.41 165.03 448 288 448c122.97 0 230.29-71.59 284.52-177.4a48.3 48.3 0 000-29.2zM288 400c-79.4 0-144-64.6-144-144s64.6-144 144-144 144 64.6 144 144-64.6 144-144 144zM288 208a48 48 0 100 96 48 48 0 000-96z"></path></svg>
						<svg class="eye-icon eye-open" viewBox="0 0 640 512" width="20" height="20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" style="display:none"><path d="M634 471L105 3c-9-8-23-7-31 2-8 9-7 23 2 31l73 66C67 146 12 200 4 208c-12 12-12 32 0 44C58 306 166 378 288 378c52 0 101-13 142-36l93 84c9 8 23 7 31-2 8-9 7-23-2-31zM288 346c-79.4 0-144-64.6-144-144 0-13 2-25 6-37l179 161c-12 6-26 9-41 9z"></path></svg>
					</button>
				</div>
				<span asp-validation-for="Password" class="text-danger small"></span>
			</div>
			<div class="flex-row">
				<div>
					<input type="checkbox">
					<label>Remember me </label>
				</div>
				<div>
					<a href="ForgotPW.cshtml" style="font-size:14px">Forgot your password?</a>
				</div>
			</div>

			<button type="submit" class="submit-btn">Login</button>
			<p class="p1">If you don't have an account yet <a asp-controller="Account" asp-action="Signup" class="signup">Sign Up</a></p>
		</form>
	</div>
</div>

<style>
	.html, body{
		margin: 0;
		padding: 0;
	}
	.login-container {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		width: 100%;
		padding: 0;
		background-color: darkgray;
	}
	.login-card {
		width: 350px;
		min-height: 500px;
		background-color: #fff;
		border-radius: 10px;
		box-sizing: border-box;
		padding: 40px 30px 30px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		align-items: stretch;
		justify-content: flex-start;
	}
	.form-control{
		width: 100%;
		margin-top: 0;
		border-radius: 8px;
		border: 1px solid #ccc;
		padding: 12px 15px;
	}
	.mb-3{
		margin-bottom: 16px;
	}
	.submit-btn{
		padding: 1rem 0.75rem;
		width: 100%;
		display: inline-flex;
		justify-content: center;
		align-items: center;
		border-radius: 3rem;
		background-color: lightgray;
		color: black;
		border: none;
		cursor: pointer;
		transition: background-color 300ms ease, transform 300ms ease;
		font-weight: 600;
		font-size: 0.95rem;
		margin-top: 10px;
	}

	.submit-btn:hover {
		background-color: gray;
		transform: translateY(-1px);
	}

	.login-title {
		margin: 0 0 30px 0;
		text-align: center;
		font-family: "Lucida Sans", "Lucida Sans Regular", "Lucida Grande", "Lucida Sans Unicode", Geneva, Verdana, sans-serif;
		font-size: 28px;
		font-weight: 800;
	}

	.password-wrapper {
		position: relative;
	}
	.password-input {
		padding-right: 44px;
	}
	.password-toggle {
		position: absolute;
		right: 10px;
		top: 50%;
		transform: translateY(-50%);
		display: none;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: none;
		padding: 4px;
		cursor: pointer;
		color: #333;
	}
	.password-toggle:focus {
		outline: 2px solid rgba(78,70,255,0.16);
		border-radius: 4px;
	}
	.password-wrapper.has-value .password-toggle {
		display: inline-flex;
	}
	.eye-icon {
		display: block;
		fill: #333;
		width: 20px;
		height: 20px;
		pointer-events: none;
	}

	.p1, .signup {
		text-align: center;
		font-family: "Lucida Sans", "Lucida Sans Regular", "Lucida Grande", "Lucida Sans Unicode", Geneva, Verdana, sans-serif;
		font-size: 12px;
		font-weight: 400;
	}
	.signup {
		color: black;
		transition: 0.3s ease-in-out;
	}

	.signup:hover {
		color: blueviolet;
	}
	.flex-row {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 10px;
		justify-content: space-between;
	}

	.flex-row > div > label {
		font-size: 14px;
		color: black;
		font-weight: 400;
	}
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
	var pw = document.getElementById('Password');
	if (!pw) return;
	var wrapper = pw.closest('.password-wrapper');
	var toggle = wrapper && wrapper.querySelector('.password-toggle');
	var eyeOpen = toggle && toggle.querySelector('.eye-open');
	var eyeClosed = toggle && toggle.querySelector('.eye-closed');

	function updateToggleVisibility() {
		if (pw.value && pw.value.length > 0) wrapper.classList.add('has-value');
		else wrapper.classList.remove('has-value');
	}

	pw.addEventListener('input', updateToggleVisibility);
	updateToggleVisibility();

	if (toggle) {
		toggle.addEventListener('click', function () {
			var isText = pw.type === 'text';
			pw.type = isText ? 'password' : 'text';
			toggle.setAttribute('aria-pressed', (!isText).toString());
			toggle.setAttribute('aria-label', pw.type === 'text' ? 'Hide password' : 'Show password');
			if (eyeOpen && eyeClosed) {
				if (pw.type === 'text') { eyeOpen.style.display = 'inline-block'; eyeClosed.style.display = 'none'; }
				else { eyeOpen.style.display = 'none'; eyeClosed.style.display = 'inline-block'; }
			}
			pw.focus();
		});
	}
});
</script>
