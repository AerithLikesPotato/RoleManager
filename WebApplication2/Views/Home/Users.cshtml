@model List<WebApplication2.Models.User>
@{
    ViewData["Title"] = "Users";
    var roles = (List<WebApplication2.Models.Role>)ViewBag.Roles;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/html.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user.css" asp-append-version="true" />
</head>
<body>
    <div class="container">
        @await Html.PartialAsync("_Notifications")
        <header class="navbar">
            <div class="logo-section">
                <a asp-controller="Home" asp-action="Home" class="logo-link">
                    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12.645 5.264a1.25 1.25 0 0 0-1.29 0l-.516.31a10.75 10.75 0 0 1-4.537 1.494l-.325.03a.25.25 0 0 0-.227.25V8.99a9.25 9.25 0 0 0 2.82 6.65l3.256 3.148a.25.25 0 0 0 .348 0l3.255-3.147a9.25 9.25 0 0 0 2.821-6.65V7.346a.25.25 0 0 0-.227-.248l-.325-.031a10.75 10.75 0 0 1-4.537-1.493zM10.58 3.979a2.75 2.75 0 0 1 2.838 0l.516.31a9.25 9.25 0 0 0 3.904 1.286l.325.03a1.75 1.75 0 0 1 1.586 1.742v1.644a10.75 10.75 0 0 1-3.278 7.73l-3.256 3.146a1.75 1.75 0 0 1-2.432 0L7.528 16.72A10.75 10.75 0 0 1 4.25 8.991V7.347a1.75 1.75 0 0 1 1.586-1.742l.325-.03a9.25 9.25 0 0 0 3.904-1.285z" clip-rule="evenodd"></path></svg>
                    Vantage
                </a>
            </div>

            <ul class="nav">
                <li class="nav-item search-item">
                    <form class="search-form" action="#" method="get">
                        <input type="search" name="q" placeholder="Search users, roles..." aria-label="Search" />
                        <button type="submit" aria-label="Submit search">
                            <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" viewBox="0 0 24 24"><path fill="currentColor" d="M10.5 3a7.5 7.5 0 1 1-7.5 7.5A7.51 7.51 0 0 1 10.5 3m0-1A8.5 8.5 0 1 0 19 10.5A8.51 8.51 0 0 0 10.5 2zM21.71 20.29l-4-4a1.003 1.003 0 0 0-1.42-1.42l-4-4a1.003 1.003 0 0 0-1.42-1.42l-4-4a1.003 1.003 0 0 0-1.42-1.42l-4-4a1.003 1.003 0 0 0-1.42-1.42l-.29-.29a1.003 1.003 0 0 0-.29-.71L2 .29a1.003 1.003 0 0 0-.71-.29H2a1.003 1.003 0 0 0-.71-.29L2 .29a1.003 1.003 0 0 0 .29.71l.29.29z"/></svg>
                        </button>
                    </form>
                </li>
                @await Html.PartialAsync("_NotificationBell")
                <li>
                    <div class="profile-dropdown" onclick="toggleDropdown(event)">
                        <img src="~/images/profile/pfp1.jpg" alt="Profile" style="width: 38px; height: 38px; border-radius: 50%; object-fit: cover;" />
                        <div class="profileDetail">
                            <span style="font-size: 0.85rem; font-weight: bold; color: #ffff;">@(User?.Identity?.Name ?? "Jonh Doe")</span>
                            <span style="font-size: 0.75rem; color: #64748b;">@(User?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer")</span>
                        </div>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        <div id="myDropdown" class="dropdown-menu">
                            <a asp-controller="Home" asp-action="Profile">My Profile</a>
                            <a asp-controller="Home" asp-action="Settings">Setting</a>
                            <a asp-controller="Account" asp-action="Login">Signout</a>
                        </div>
                    </div>
                </li>
            </ul>
        </header>

        <div class="page-layout">
            <aside class="sidebar">
                <p class="sidebar-title">Workspace</p>
                <ul class="nav2">
                    <li class="nav-item2">
                        <a asp-controller="Home" asp-action="Home"><svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M4 5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1zm10 0a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1zM4 16a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1zm10-3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1z"/></svg>Dashboard</a>
                    </li>
                    <li class="nav-item2">
                        <a asp-controller="Home" asp-action="Users" class="active"><svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M3 19v-1a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v1m6 0v-1a4 4 0 0 0-4-4m-2.5-8.83a3 3 0 1 1 0 5.659M12 8a3 3 0 1 1-6 0a3 3 0 0 1 6 0Z"/></svg>Users</a>
                    </li>
                    <li class="nav-item2">
                        <a asp-controller="Home" asp-action="Roles"><svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="img" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12.645 5.264a1.25 1.25 0 0 0-1.29 0l-.516.31a10.75 10.75 0 0 1-4.537 1.494l-.325.03a.25.25 0 0 0-.227.25V8.99a9.25 9.25 0 0 0 2.82 6.65l3.256 3.148a.25.25 0 0 0 .348 0l3.255-3.147a9.25 9.25 0 0 0 2.821-6.65V7.346a.25.25 0 0 0-.227-.248l-.325-.031a10.75 10.75 0 0 1-4.537-1.493zM10.58 3.979a2.75 2.75 0 0 1 2.838 0l.516.31a9.25 9.25 0 0 0 3.904 1.286l.325.03a1.75 1.75 0 0 1 1.586 1.742v1.644a10.75 10.75 0 0 1-3.278 7.73l-3.256 3.146a1.75 1.75 0 0 1-2.432 0L7.528 16.72A10.75 10.75 0 0 1 4.25 8.991V7.347a1.75 1.75 0 0 1 1.586-1.742l.325-.03a9.25 9.25 0 0 0 3.904-1.285z" clip-rule="evenodd"></path></svg>Roles</a>
                    </li>
                </ul>
                <div class="sidebar-footer">
                    <p>Vantage Enterprise<br>Design showcase build</p>
                </div>
            </aside>

            <main class="main-content">
            <div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #1e293b;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom:1.5rem; margin-top:2rem;">
                    <div>
                        <span style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">Directory</span>
                        <h2 style="font-size:1.75rem; font-weight: 700; margin: 0.25rem 0 0 0; color: #0f172a;">Users</h2>
                        <p style="color: #64748b; font-size:0.85rem; margin: 0.25rem 0 0 0;">Accounts that have access to this workspace.</p>
                    </div>
                    <button type="button" onclick="openPopUp('createUserModal')" style="background-color: #0f4c81; color: white; border:none; padding: 0.6rem 1.2rem; font-weight: 600; border-radius: 8px; cursor: pointer; display: flex; align-items:center; gap:0.5rem; font-size: 0.9rem;">
                        <span style="font-size: 1.1rem; font-weight: bold;">+</span>Create User
                    </button>
                </div>

                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.85rem;">
                        <thead style="background-color: #fafafa; color: #64748b; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">
                            <tr>
                                <th style="padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">USER</th>
                                <th style="padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">ROLE</th>
                                <th style="padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">STATUS</th>
                                <th style="padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">JOINED</th>
                                <th style="padding: 1rem 1.5rem; text-align: right; border-bottom: 1px solid #e2e8f0;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                var statusClass = u.Status == "active" ? "active" : (u.Status == "suspended" ? "suspend" : "inactive");
                                var statusLabel = u.Status == "active" ? "Active" : (u.Status == "suspended" ? "Suspended" : "Inactive");
                                <tr>
                                    <td class="userName">
                                        <img src="@(string.IsNullOrEmpty(u.AvatarUrl) ? "/images/profile/pfp1.jpg" : u.AvatarUrl)" alt="@u.FullName" width="32" height="32" style="border-radius: 50%; margin-right: 0.5rem;">
                                        @u.FullName
                                        <p style="margin: 0.2rem 0 0; color: #64748b; font-size: 0.8rem;">@u.Email</p>
                                    </td>
                                    <td style="padding: 1.25rem 1.5rem;">
                                        <span style="background-color: rgba(59, 141, 247, 0.548); color: #25418d; padding: 0.25rem 0.6rem; border-radius: 20px; font-weight: bold; font-size: 0.8rem;">@(u.Role?.Name ?? "No role")</span>
                                    </td>
                                    <td class="userStatus-@statusClass">
                                        <span class="status-pill-@statusClass">
                                            <span class="status-dot-@statusClass"></span>
                                            <span class="status-text-@statusClass">@statusLabel</span>
                                        </span>
                                    </td>
                                    <td class="userJoined">@u.CreatedAt.ToString("MMM d, yyyy")</td>
                                    <td class="edit"><button type="button" onclick="openEditUserModal(this)" data-id="@u.id" data-fullname="@u.FullName" data-email="@u.Email" data-roleid="@(u.RoleID ?? 0)" data-status="@u.Status" aria-label="Edit user" style="background: transparent; border: none; color: #0f4c81; font-size: 0.85rem; cursor: pointer; font-weight: 600;">Edit</button></td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr><td colspan="5" style="padding: 1.5rem; text-align:center; color:#64748b;">No users yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div id="createUserModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="createUserTitle">
        <div class="modal-card">
            <h3 id="createUserTitle">Create New User</h3>
            <p>Fill out the information details below to add a new account.</p>
            <form id="createUserForm" asp-controller="Home" asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="Username" placeholder="Enter username" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="Email" placeholder="Enter email" required>
                </div>
                <div class="form-group">
                    <label for="password">Temporary Password</label>
                    <input type="password" id="password" name="Password" placeholder="Enter a temporary password" minlength="6" required>
                </div>
                <div class="form-group">
                    <label for="role">Role</label>
                    <select id="role" name="RoleId" required>
                        <option value="">Select a role</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role.ID">@role.Name</option>
                        }
                    </select>
                </div>
                <div class="modal-actions">
                    <button type="button" onclick="closePopUp('createUserModal')" class="btn-cancel">Cancel</button>
                    <button type="submit" class="btn-submit">Submit</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editUserModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="editUserTitle">
        <div class="modal-card">
            <h3 id="editUserTitle">Edit User</h3>
            <p>Update the selected account details below.</p>
            <form id="editUserForm" asp-controller="Home" asp-action="UpdateUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editUserId" name="Id" />
                <div class="form-group">
                    <label for="editFullName">Full Name</label>
                    <input type="text" id="editFullName" name="FullName" placeholder="Enter full name" required>
                </div>
                <div class="form-group">
                    <label for="editUserEmail">Email</label>
                    <input type="email" id="editUserEmail" name="Email" placeholder="Enter email" required>
                </div>
                <div class="form-group">
                    <label for="editUserRole">Role</label>
                    <select id="editUserRole" name="RoleId" required>
                        <option value="">Select a role</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role.ID">@role.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="editUserStatus">Account Status</label>
                    <select id="editUserStatus" name="Status" required>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="suspended">Suspended</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button type="button" onclick="closePopUp('editUserModal')" class="btn-cancel">Cancel</button>
                    <button type="submit" class="btn-submit">Save Changes</button>
                </div>
            </form>
            <form id="deleteUserForm" asp-controller="Home" asp-action="DeleteUser" method="post" style="margin-top: 0.75rem;">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteUserId" name="Id" />
                <button type="submit" class="btn-delete">Delete User</button>
            </form>
        </div>
    </div>

    <script src="~/js/profile.js" asp-append-version="true"></script>
    <script src="~/js/modal.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
</body>
</html>